{
  "name": "commit-maker",
  "displayName": "Commit Maker – コミットメーカー",
  "description": "Git差分からコミットメッセージをAI生成。BYOK、Codex、Qwen3/Gemma 4/LFM2.5のローカルGGUFモデルに対応。",
  "version": "0.6.10",
  "publisher": "Hiromitsu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hiromitsu-A-T/commit-maker.git"
  },
  "homepage": "https://github.com/Hiromitsu-A-T/commit-maker#readme",
  "bugs": {
    "url": "https://github.com/Hiromitsu-A-T/commit-maker/issues"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "commit message",
    "commit generator",
    "commit ai",
    "commit auto",
    "scm",
    "scm input",
    "ai",
    "auto commit message",
    "ai commit message",
    "llm",
    "local llm",
    "llama.cpp",
    "gguf",
    "qwen",
    "qwen3",
    "gemma",
    "gemma 4",
    "lfm",
    "lfm2.5",
    "liquid ai",
    "byok",
    "openai",
    "gemini",
    "claude",
    "codex",
    "chatgpt",
    "vscode",
    "コミット",
    "コミットメッセージ",
    "コミット生成",
    "コミット自動生成",
    "コミットメーカー",
    "AIコミット",
    "AIコミットメッセージ",
    "コミットメッセージ自動生成",
    "Git コミット",
    "差分から生成",
    "Git 拡張",
    "ローカルLLM",
    "クエン",
    "ジェンマ",
    "SecretStorage"
  ],
  "galleryBanner": {
    "color": "#0b1726",
    "theme": "dark"
  },
  "icon": "media/commit-maker.png",
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Git 差分を読み取り、外部 LLM またはローカル runtime へ渡すため、信頼済みワークスペースでのみ有効化します。"
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "commitMaker.showPanel",
        "title": "%command.commitMaker.showPanel.title%",
        "icon": "$(panel-right)"
      },
      {
        "command": "commitMaker.generateCommitFromSCM",
        "title": "%command.commitMaker.generateCommitFromSCM.title%",
        "category": "%command.commitMaker.category%",
        "icon": "$(wand)"
      },
      {
        "command": "commitMaker.cancelCommitFromSCM",
        "title": "%command.commitMaker.cancelCommitFromSCM.title%",
        "category": "%command.commitMaker.category%",
        "icon": "$(stop)"
      },
      {
        "command": "commitMaker.saveApiKey",
        "title": "%command.commitMaker.saveApiKey.title%",
        "category": "%command.commitMaker.category%",
        "icon": "$(key)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commitMaker.generateCommitFromSCM",
          "group": "navigation@9",
          "when": "scmProvider == git && !commitMaker.commitGenerating"
        },
        {
          "command": "commitMaker.cancelCommitFromSCM",
          "group": "navigation@8",
          "when": "scmProvider == git && commitMaker.commitGenerating"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.commitMaker.title%",
      "properties": {
        "commitMaker.provider": {
          "type": "string",
          "enum": [
            "gemini",
            "openai",
            "claude",
            "codex",
            "local"
          ],
          "default": "gemini",
          "description": "選択する LLM プロバイダー"
        },
        "commitMaker.endpoint": {
          "type": "string",
          "scope": "application",
          "default": "https://api.openai.com/v1/responses",
          "description": "OpenAI (Responses/Chat Completions) 用エンドポイント"
        },
        "commitMaker.endpointGemini": {
          "type": "string",
          "scope": "application",
          "default": "https://generativelanguage.googleapis.com/v1beta/models",
          "description": "Google Gemini generateContent ベース URL"
        },
        "commitMaker.endpointClaude": {
          "type": "string",
          "scope": "application",
          "default": "https://api.anthropic.com/v1/messages",
          "description": "Anthropic Claude messages API エンドポイント"
        },
        "commitMaker.endpointLocal": {
          "type": "string",
          "scope": "application",
          "default": "http://127.0.0.1",
          "description": "Local provider 内部用エンドポイント（通常は変更不要）"
        },
        "commitMaker.codexCommand": {
          "type": "string",
          "scope": "application",
          "default": "codex",
          "description": "Codex provider が専用 CODEX_HOME で使用する Codex CLI コマンドまたは実行ファイルパス"
        },
        "commitMaker.model": {
          "type": "string",
          "default": "gemini-2.5-flash-lite",
          "description": "コミット生成に使用するモデル ID"
        },
        "commitMaker.reasoningEffort": {
          "type": "string",
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "medium",
          "description": "OpenAI Responses API 用 reasoning.effort"
        },
        "commitMaker.codexReasoningEffort": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "low",
          "description": "Codex provider 用 model_reasoning_effort"
        },
        "commitMaker.verbosity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "default": "medium",
          "description": "OpenAI Responses API の text.verbosity"
        },
        "commitMaker.apiKeySecret": {
          "type": "string",
          "scope": "application",
          "default": "commit-maker/api-key",
          "description": "OpenAI 用 API キーを保存する SecretStorage のキー名"
        },
        "commitMaker.apiKeySecretGemini": {
          "type": "string",
          "scope": "application",
          "default": "commit-maker/api-key/gemini",
          "description": "Gemini 用 API キーを保存する SecretStorage のキー名"
        },
        "commitMaker.apiKeySecretClaude": {
          "type": "string",
          "scope": "application",
          "default": "commit-maker/api-key/claude",
          "description": "Claude 用 API キーを保存する SecretStorage のキー名"
        },
        "commitMaker.apiKeySecretLocal": {
          "type": "string",
          "scope": "application",
          "default": "",
          "description": "Local provider は API キーを使用しません"
        },
        "commitMaker.localRuntimePath": {
          "type": "string",
          "scope": "application",
          "default": "",
          "description": "自動取得 runtime を使わない場合の llama-server 実行ファイルパス"
        },
        "commitMaker.localModelUrl": {
          "type": "string",
          "scope": "application",
          "default": "",
          "description": "空なら選択モデルを使用。指定時は Local provider の GGUF モデル URL を上書き"
        },
        "commitMaker.localModelFilename": {
          "type": "string",
          "scope": "application",
          "default": "",
          "description": "空なら選択モデルを使用。指定時は Local provider の保存ファイル名を上書き"
        },
        "commitMaker.localModelSha256": {
          "type": "string",
          "scope": "application",
          "default": "",
          "description": "空なら選択モデルを使用。指定時は Local provider の GGUF モデル検証用 SHA256 を上書き"
        },
        "commitMaker.localContextSize": {
          "type": "number",
          "default": 32768,
          "description": "Local provider の llama.cpp context size"
        },
        "commitMaker.localThreads": {
          "type": "number",
          "default": 0,
          "description": "Local provider の CPU スレッド数。0 で llama.cpp に任せる"
        },
        "commitMaker.localGpuLayers": {
          "type": "number",
          "default": 99,
          "description": "Local provider の GPU offload layers"
        },
        "commitMaker.localKeepAliveMs": {
          "type": "number",
          "default": 300000,
          "description": "Local provider の llama-server を生成後に保持する時間（ミリ秒）。0 で自動停止しない"
        },
        "commitMaker.requestTimeoutMs": {
          "type": "number",
          "default": 300000,
          "description": "LLM 呼び出しタイムアウト (ミリ秒)。0 で無制限"
        },
        "commitMaker.maxOutputTokens": {
          "type": "number",
          "default": 8192,
          "description": "OpenAI /v1/responses へ送る max_output_tokens の上限"
        },
        "commitMaker.diffCollectionLimitChars": {
          "type": "number",
          "scope": "application",
          "default": 33554432,
          "minimum": 1000000,
          "description": "差分収集段階の安全上限（文字数）。最終プロンプト上限とは別で、長コンテキストモデル向けに必要なら引き上げ可能"
        },
        "commitMaker.logLlm": {
          "type": "boolean",
          "default": false,
          "description": "LLM へのリクエスト/リトライを Output チャネルに記録する"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commitMakerContainer",
          "title": "%views.activitybar.commitMaker.title%",
          "icon": "media/commit-maker-activitybar.svg"
        }
      ]
    },
    "views": {
      "commitMakerContainer": [
        {
          "id": "commitMakerView",
          "name": "%views.commitMakerContainer.commitMakerView.name%",
          "type": "webview",
          "icon": "media/commit-maker-activitybar.svg"
        }
      ]
    }
  },
  "scripts": {
    "clean:out": "node scripts/clean-out.js",
    "check:commit-emails": "node scripts/check-commit-emails.js --all",
    "precompile": "npm run clean:out",
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "test": "ts-node --project tsconfig.json src/testRunner.ts",
    "dev:prep": "npm run build:nls && npm run compile",
    "update:badges": "node scripts/update-badges.js",
    "build:nls": "node scripts/copy-package-nls.js",
    "clean:nls": "node scripts/clean-package-nls.js",
    "package": "npm run compile && npm run build:media && npm run build:nls && npx vsce package --no-dependencies --no-rewrite-relative-links && npm run clean:nls",
    "package:preview": "npm run compile && npm run build:media && npm run build:nls && npx vsce package --pre-release --no-dependencies --no-rewrite-relative-links && npm run clean:nls",
    "publish:marketplace": "npx vsce publish",
    "publish:openvsx": "npx ovsx publish --packagePath vsix/commit-maker-*.vsix",
    "clean:vsix": "node scripts/clean-vsix.js",
    "build:media": "tsc -p media/tsconfig.json",
    "smoke:openai": "ts-node --transpile-only scripts/smoke-openai.ts",
    "smoke:openai:response": "ts-node --transpile-only scripts/smoke-openai-response.ts",
    "smoke:openai:matrix": "ts-node --transpile-only scripts/smoke-openai-matrix.ts",
    "smoke:gemini": "ts-node --transpile-only scripts/smoke-gemini.ts",
    "smoke:gemini:matrix": "ts-node --transpile-only scripts/smoke-gemini-matrix.ts",
    "smoke:claude": "ts-node --transpile-only scripts/smoke-claude.ts",
    "smoke:claude:matrix": "ts-node --transpile-only scripts/smoke-claude-matrix.ts",
    "smoke:cloud:minimal": "ts-node --transpile-only scripts/smoke-cloud-minimal.ts",
    "smoke:local:runtime": "ts-node --project tsconfig.json scripts/smoke-local-runtime.ts"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "1.94.0",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "^0.10.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
